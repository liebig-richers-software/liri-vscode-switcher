{
  "name": "vscode-switcher",
  "packageManager": "pnpm@10.30.3",
  "version": "0.1.0",
  "description": "A sidebar launcher for quickly switching between VS Code project windows",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": ["vscode", "productivity", "window-manager", "developer-tools"],
  "author": "Liebig Richers Software",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "de.liebig-richers.vscode-switcher",
    "productName": "VSCode Switcher",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
