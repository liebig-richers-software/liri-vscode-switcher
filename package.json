{
  "name": "vscode-switcher",
  "packageManager": "pnpm@10.30.3",
  "version": "0.1.0",
  "description": "A sidebar launcher for quickly switching between VS Code project windows",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "prebuild": "node -e \"try{require('child_process').execSync('taskkill /F /IM electron.exe /T',{stdio:'ignore'})}catch(e){}\"",
    "build": "electron-builder"
  },
  "keywords": [
    "vscode",
    "productivity",
    "window-manager",
    "developer-tools"
  ],
  "author": "Liebig Richers Software GmbH",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "koffi"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "de.lirisoft.vscode-switcher",
    "productName": "VSCode Switcher",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "koffi": "^2.15.2"
  }
}
